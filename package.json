{
  "name": "blog-aggregator",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "npx tsc",
    "start": "tsx ./src/index.ts",
    "dev": "npx tsc && node dist/index.js",
    "tee": "npm run dev | tee repl.log",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate"
  },
  "keywords": ["rss", "feed-aggregator", "blog", "typescript"],
  "author": "FahimOrko",
  "license": "ISC",
  "description": "A TypeScript-based RSS feed aggregator that fetches and manages blog content from multiple sources into a PostgreSQL database",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.9.3",
    "postgres": "^3.4.9"
  }
}
